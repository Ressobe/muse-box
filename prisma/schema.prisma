generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  username   String   @unique
  avatar_img String
  password   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile?
}

model Profile {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id])
  userId Int  @unique

  artistId Int?
  albumId  Int?
  songId   Int?

  favourite_artist Artist? @relation(fields: [artistId], references: [id])
  favourite_album  Album?  @relation(fields: [albumId], references: [id])
  favourite_song   Song?   @relation(fields: [songId], references: [id])

  comments  Comment[]
  friends   Profile[]   @relation("Friends")
  friendOf  Profile[]   @relation("Friends")
  Following Following[]
}

model Following {
  id        Int     @id @default(autoincrement())
  profile   Profile @relation(fields: [profileId], references: [id])
  profileId Int
  artist    Artist  @relation(fields: [artistId], references: [id])
  artistId  Int

  @@unique([profileId, artistId])
}

model Artist {
  id                 Int         @id @default(autoincrement())
  nick               String      @unique
  name               String
  surname            String
  age                Int
  place_of_birth     String
  nationality        String
  language           String
  avatar_img         String
  banner_img         String?
  views              Int         @default(0)
  avg_rate           Int         @default(0)
  amount_of_comments Int         @default(0)
  about              String?
  spotify_link       String?
  youtube_link       String?
  soundcloud_link    String?
  instagram_link     String?
  twitter_link       String?
  albums             Album[]
  comments           Comment[]
  favourite          Profile[]
  genres             Genre[]     @relation("ArtistGenres")
  Following          Following[]
}

model Album {
  id            Int        @id @default(autoincrement())
  creatorId     Int
  title         String
  img           String
  total_tracks  Int
  spotify_link  String
  release_year  Int
  release_month Int?
  release_day   Int?
  language      String
  typeId        Int
  type          Album_Type @relation(fields: [typeId], references: [id])
  creator       Artist     @relation(fields: [creatorId], references: [id])
  comments      Comment[]
  songs         Song[]
  favourite     Profile[]
}

model Album_Type {
  id    Int     @id @default(autoincrement())
  type  String  @unique
  Album Album[]
}

model Song {
  id           Int       @id @default(autoincrement())
  title        String
  albumId      Int
  track_number Int
  duration_ms  Int
  genreId      Int
  spotify_link String
  language     String
  album        Album     @relation(fields: [albumId], references: [id])
  comments     Comment[]
  favourite    Profile[]
}

model Genre {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  artists Artist[] @relation("ArtistGenres")
}

model Comment {
  id        Int     @id @default(autoincrement())
  content   String
  rate      Int
  userId    Int
  songId    Int?
  albumId   Int?
  artistId  Int?
  artist    Artist? @relation(fields: [artistId], references: [id])
  album     Album?  @relation(fields: [albumId], references: [id])
  song      Song?   @relation(fields: [songId], references: [id])
  Profile   Profile @relation(fields: [profileId], references: [id])
  profileId Int
}
