generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  username   String   @unique
  avatar_img String
  password   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile?
}

model Profile {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  artistId String?
  albumId  String?
  songId   String?

  favourite_artist Artist? @relation(fields: [artistId], references: [id])
  favourite_album  Album?  @relation(fields: [albumId], references: [id])
  favourite_song   Track?  @relation(fields: [songId], references: [id])

  comments Comment[]
  friends  Profile[] @relation("Friends")
  friendOf Profile[] @relation("Friends")

  invitationsSent     Invitation[]   @relation("sentBy")
  invitationsReceived Invitation[]   @relation("receivedBy")
  notifications       Notification[]
  Playlist            Playlist[]
}

model Playlist {
  id      String  @id @default(uuid())
  name    String
  owner   Profile @relation(fields: [ownerId], references: [id])
  ownerId String
  tracks  Track[]
}

model Notification {
  id Int @id @default(autoincrement())

  Profile   Profile? @relation(fields: [profileId], references: [id])
  profileId String?

  type       String
  from       Int
  resourceId Int
  isRead     Boolean

  createdAt DateTime @default(now())
}

model Invitation {
  id         Int     @id @default(autoincrement())
  sender     Profile @relation(name: "sentBy", fields: [senderId], references: [id])
  senderId   String
  receiver   Profile @relation(name: "receivedBy", fields: [receiverId], references: [id])
  receiverId String

  createdAt DateTime @default(now())

  @@unique([senderId, receiverId])
}

model Artist {
  id             String  @id @default(uuid())
  nick           String  @unique
  name           String  @default("")
  surname        String  @default("")
  age            Int     @default(10)
  place_of_birth String  @default("")
  nationality    String  @default("")
  language       String  @default("")
  avatar_img     String
  banner_img     String?

  views              Int @default(0)
  avg_rate           Int @default(0)
  amount_of_comments Int @default(0)

  about           String?
  spotify_link    String?
  youtube_link    String?
  soundcloud_link String?
  instagram_link  String?
  twitter_link    String?

  albums    Album[]
  comments  Comment[]
  favourite Profile[]
  genres    Genre[]   @relation("ArtistGenres")
}

model Album {
  id              String     @id @default(uuid())
  creatorId       String
  title           String
  img             String
  total_tracks    Int
  spotify_link    String
  youtube_link    String?
  soundcloud_link String?
  release_year    Int
  release_month   Int?
  release_day     Int?
  language        String
  typeId          Int
  type            Album_Type @relation(fields: [typeId], references: [id])
  creator         Artist     @relation(fields: [creatorId], references: [id])
  comments        Comment[]
  songs           Track[]
  favourite       Profile[]
}

model Album_Type {
  id    Int     @id @default(autoincrement())
  type  String  @unique
  Album Album[]
}

model Track {
  id              String    @id @default(uuid())
  title           String
  albumId         String
  track_number    Int
  duration_ms     Int
  genreId         Int
  spotify_link    String
  youtube_link    String?
  soundcloud_link String?
  language        String    @default("")
  album           Album     @relation(fields: [albumId], references: [id])
  comments        Comment[]
  favourite       Profile[]
  Playlist        Playlist? @relation(fields: [playlistId], references: [id])
  playlistId      String?
}

model Genre {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  artists Artist[] @relation("ArtistGenres")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  rate      Int
  userId    Int
  songId    String?
  albumId   String?
  artistId  String?
  artist    Artist?  @relation(fields: [artistId], references: [id])
  album     Album?   @relation(fields: [albumId], references: [id])
  song      Track?   @relation(fields: [songId], references: [id])
  Profile   Profile  @relation(fields: [profileId], references: [id])
  profileId String
  createdAt DateTime @default(now())
}
