generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// User
// ---------------------------------------------------------------------

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  username   String   @unique
  avatar_img String   @default("/user.png")
  password   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile?
}

model Profile {
  id      String @id @default(uuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String @unique
  name    String @default("")
  surname String @default("")
  age     Int    @default(0) @db.SmallInt

  comment       Comment[]
  playlist      Playlist[]
  notifications Notification[] @relation("ProfileNotifications")

  followers       Profile[] @relation("Following")
  following       Profile[] @relation("Following")
  followedArtists Artist[]  @relation("FollowedArtists")

  artistId String?
  albumId  String?
  trackId  String?
  genreId  String?

  favourite_artist Artist?    @relation(fields: [artistId], references: [id])
  favourite_album  Recording? @relation(fields: [albumId], references: [id])
  favourite_song   Track?     @relation(fields: [trackId], references: [id])
  favourite_genre  Genre?     @relation(fields: [genreId], references: [id])

  invitationsSent      Invitation[]   @relation("sentBy")
  invitationsReceived  Invitation[]   @relation("receivedBy")
  stats                ProfileStats?
  friends              Profile[]      @relation("Friends")
  friendsOf            Profile[]      @relation("Friends")
  createdNotifications Notification[]
}

model ProfileStats {
  id Int @id @default(autoincrement())

  owner   Profile @relation(fields: [ownerId], references: [id])
  ownerId String  @unique

  amount_of_ratings   Int
  amount_of_followers Int
  amount_of_following Int
}

model Playlist {
  id   String @id @default(uuid())
  name String

  isPublic Boolean
  owner    Profile @relation(fields: [ownerId], references: [id])
  ownerId  String

  tracks     Track[]
  recordings Recording[]
}

enum InvitationState {
  PENDING
  ACCEPTED
  REJECTED
}

model Invitation {
  id String @id @default(uuid())

  sender   Profile @relation(name: "sentBy", fields: [senderId], references: [id])
  senderId String

  receiver   Profile @relation(name: "receivedBy", fields: [receiverId], references: [id])
  receiverId String

  state InvitationState

  createdAt DateTime @default(now())
}

enum NotificationType {
  NEW_ALBUM
  NEW_SONG
  NEW_RATE_FROM_FRIEND
  NEW_FOLLOWER
  ACCEPTED_INVITATION
  INVITE
}

model Notification {
  id         Int              @id @default(autoincrement())
  type       NotificationType
  resourceId String?
  isRead     Boolean          @default(false)
  isSeen     Boolean          @default(false)
  from       Profile          @relation(fields: [fromId], references: [id])
  fromId     String
  createdAt  DateTime         @default(now())
  profiles   Profile[]        @relation("ProfileNotifications")
}

enum CommentType {
  ARTIST
  RECORDING
  TRACK
}

model Comment {
  id      String      @id @default(uuid())
  rate    Int
  type    CommentType
  content String
  owner   Profile     @relation(fields: [ownerId], references: [id])
  ownerId String

  artistId    String?
  recordingId String?
  trackId     String?

  artist    Artist?    @relation(fields: [artistId], references: [id])
  recording Recording? @relation(fields: [recordingId], references: [id])
  track     Track?     @relation(fields: [trackId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------
// ARTIST
// ---------------------------------------------------------------------

enum ArtistType {
  PERSON
  GROUP
  ORCHESTRA
  CHOIR
  CHARACTER
  OTHER
}

enum GenderType {
  MALE
  FEMALE
  OTHER
}

model Artist {
  id     String     @id @default(uuid())
  name   String
  type   ArtistType
  gender GenderType

  mbid  String
  about String?

  area   Area?   @relation(fields: [areaId], references: [id])
  areaId String?

  begin_date_day   Int? @db.SmallInt
  begin_date_month Int? @db.SmallInt
  begin_date_year  Int? @db.SmallInt

  end_date_day   Int? @db.SmallInt
  end_date_month Int? @db.SmallInt
  end_date_year  Int? @db.SmallInt

  popularity     Int                  @default(0)
  albums         Recording[]
  genres         Genre[]
  tags           Tag[]
  stats          ArtistStats?
  external_links ExternalLinkArtist[]

  comments   Comment[]
  fav_artist Profile[]
  followedBy Profile[] @relation("FollowedArtists")
}

model ArtistStats {
  id                Int   @id @default(autoincrement())
  avg_rating        Float @default(0)
  amount_of_ratings Int   @default(0)

  amount_of_albums  Int @default(0)
  amount_of_singles Int @default(0)
  amount_of_tracks  Int @default(0)

  amount_of_followers Int @default(0)

  visits  Int    @default(0)
  owner   Artist @relation(fields: [ownerId], references: [id])
  ownerId String @unique
}

model ExternalLinkArtist {
  id      Int    @id @default(autoincrement())
  link    String
  owner   Artist @relation(fields: [ownerId], references: [id])
  ownerId String
}

model Genre {
  id      String    @id @default(uuid())
  name    String    @unique
  artists Artist[]
  Profile Profile[]
}

model Tag {
  id      String   @id @default(uuid())
  name    String   @unique
  artists Artist[]
}

enum AreaType {
  COUNTRY
  SUBDIVISION
  CITY
  MUNICIPALITY
  DISTRICT
  ISLAND
  OTHER
}

model Area {
  id   String @id @default(uuid())
  mbid String
  name String @unique

  begin_date_day   Int? @db.SmallInt
  begin_date_month Int? @db.SmallInt
  begin_date_year  Int? @db.SmallInt

  end_date_day   Int? @db.SmallInt
  end_date_month Int? @db.SmallInt
  end_date_year  Int? @db.SmallInt

  type    AreaType
  artists Artist[]
}

// ---------------------------------------------------------------------
// Recording
// ---------------------------------------------------------------------

model Label {
  id         String      @id @default(uuid())
  name       String      @unique
  mbid       String      @unique
  recordings Recording[]
}

enum RecordingType {
  ALBUM
  SINGLE
  EP
  COMPILATION
  SOUNDTRACK
  REMIX
  MIXTAPE
  OTHER
}

model Recording {
  id         String        @id @default(uuid())
  name       String
  mbid       String
  cover_img  String?
  type       RecordingType
  artist     Artist        @relation(fields: [artistId], references: [id])
  artistId   String
  tracks     Track[]
  length     Int?
  about      String?
  label      Label?        @relation(fields: [labelId], references: [id])
  labelId    String?
  language   Language?     @relation(fields: [languageId], references: [id])
  languageId Int?
  popularity Int           @default(0)

  date_day   Int? @db.SmallInt
  date_month Int? @db.SmallInt
  date_year  Int? @db.SmallInt

  external_links ExternalLinkRecording[]
  stats          RecordingStats?

  playlists     Playlist[]
  comments      Comment[]
  fav_recording Profile[]
}

model Language {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  Recording Recording[]
}

model RecordingStats {
  id                Int       @id @default(autoincrement())
  avg_rating        Float     @default(0)
  amount_of_ratings Int       @default(0)
  visits            Int       @default(0)
  owner             Recording @relation(fields: [ownerId], references: [id])
  ownerId           String    @unique
}

model ExternalLinkRecording {
  id      Int       @id @default(autoincrement())
  link    String
  owner   Recording @relation(fields: [ownerId], references: [id])
  ownerId String
}

// ---------------------------------------------------------------------
// Track
// ---------------------------------------------------------------------

model Track {
  id   String @id @default(uuid())
  name String
  mbid String

  recording   Recording @relation(fields: [recordingId], references: [id])
  recordingId String
  position    Int       @db.SmallInt
  length      Int?

  popularity     Int                 @default(0)
  stats          TrackStats?
  external_links ExternalLinkTrack[]
  playlists      Playlist[]
  comments       Comment[]
  fav_track      Profile[]
}

model TrackStats {
  id                Int    @id @default(autoincrement())
  avg_rating        Float  @default(0)
  amount_of_ratings Int    @default(0)
  visits            Int    @default(0)
  owner             Track  @relation(fields: [ownerId], references: [id])
  ownerId           String @unique
}

model ExternalLinkTrack {
  id      Int    @id @default(autoincrement())
  link    String
  owner   Track  @relation(fields: [ownerId], references: [id])
  ownerId String
}
